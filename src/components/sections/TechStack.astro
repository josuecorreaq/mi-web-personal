---
import type { Locale } from '../../i18n/config';
import { useTranslations } from '../../i18n/translations';
import { getTechnologies } from '../../data/technologies';

interface Props {
	locale: Locale;
}

const { locale } = Astro.props;
const t = useTranslations(locale);
const technologies = getTechnologies(locale);
---

<section id="stack" class="page-shell section-shell">
	<p class="section-kicker" data-animate-text="whole">{t.stack.kicker}</p>
	<h2 class="section-title" data-animate-text="words" data-animate-delay="80">{t.stack.title}</h2>

	<div class="mt-14 border-t border-line">
		{technologies.map((category) => (
			<div class="grid gap-5 border-b border-line py-6 sm:grid-cols-[12rem_1fr] sm:items-center">
				<h3 class="font-mono text-xs font-semibold uppercase tracking-[0.12em] text-muted" data-animate-text="whole">
					{category.name}
				</h3>
				<ul class="flex flex-wrap gap-2">
					{category.items.map((item) => (
						<li class="border border-line bg-surface px-3 py-2 font-mono text-sm text-ink transition-colors hover:border-accent hover:text-accent">
							{item}
						</li>
					))}
				</ul>
			</div>
		))}
	</div>
</section>
