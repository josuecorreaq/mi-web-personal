---
import Button from '../common/Button.astro';
import type { Locale } from '../../i18n/config';
import { useTranslations } from '../../i18n/translations';

interface Props {
	locale: Locale;
}

const { locale } = Astro.props;
const t = useTranslations(locale);
---

<section id="inicio" class="page-shell grid min-h-[calc(100svh-4.5rem)] items-center gap-14 py-16 lg:grid-cols-[1.08fr_0.92fr] lg:py-24">
	<div>
		<h1
			class="max-w-3xl font-display text-[clamp(3rem,6vw,5.75rem)] font-semibold leading-[0.94] tracking-[-0.06em] text-balance"
			data-animate-text="characters"
		>
			{t.hero.name}
		</h1>
		<p
			class="mt-5 font-mono text-sm font-semibold uppercase tracking-[0.14em] text-accent md:text-base"
			data-animate-text="whole"
			data-animate-delay="220"
		>
			{t.hero.role}
		</p>
		<p
			class="mt-6 max-w-2xl text-lg leading-8 text-muted md:text-xl"
			data-animate-text="words"
			data-animate-delay="300"
		>
			{t.hero.description}
		</p>
		<div class="mt-9 flex flex-wrap gap-3">
			<Button href="#contacto" scrollTarget="contacto">{t.hero.secondaryCta}</Button>
			<Button href="#proyectos" scrollTarget="proyectos" variant="secondary">{t.hero.primaryCta}</Button>
		</div>
	</div>

	<div class="relative mx-auto w-full max-w-[30rem] border border-line bg-surface/75 p-3.5 sm:p-5">
		<div class="flex items-center justify-between border-b border-line pb-3">
			<p class="font-mono text-[0.625rem] font-semibold uppercase tracking-[0.16em] text-muted" data-animate-text="whole" data-animate-delay="280">
				{t.hero.flowLabel}
			</p>
			<span class="font-mono text-[0.625rem] font-semibold text-accent" data-animate-text="whole" data-animate-delay="360">
				{t.hero.flowStatus}
			</span>
		</div>

		<p class="border-b border-line py-3 font-mono text-[0.7rem] text-ink">
			<span class="font-semibold text-accent">{t.hero.flowMethod}</span>
			<span class="ml-2">{t.hero.flowEndpoint}</span>
		</p>

		<div class="pt-2">
			<ol aria-label={t.hero.flowLabel}>
				{t.hero.flow.map((step, index) => (
					<li class="flex min-h-14 items-center gap-3 border-b border-line px-1 last:border-b-0">
						<span class="w-6 shrink-0 font-mono text-[0.625rem] font-semibold text-accent">
							{String(index + 1).padStart(2, '0')}
						</span>
						<span class="font-mono text-[0.7rem] text-ink" data-animate-text="whole" data-animate-delay={420 + index * 90}>
							{step}
						</span>
					</li>
				))}
			</ol>
		</div>
		<div class="absolute -right-2 -top-2 size-4 border-r border-t border-accent" aria-hidden="true"></div>
		<div class="absolute -bottom-2 -left-2 size-4 border-b border-l border-accent" aria-hidden="true"></div>
	</div>
</section>
