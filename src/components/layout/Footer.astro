---
import type { Locale } from '../../i18n/config';

interface Props {
	locale: Locale;
}

const { locale } = Astro.props;
const name = locale === 'es' ? 'Josué Correa' : 'Josue Correa';
---

<footer class="border-t border-line">
	<div class="page-shell py-8 text-center text-sm text-muted">
		<p>© {new Date().getFullYear()} {name}</p>
	</div>
</footer>
